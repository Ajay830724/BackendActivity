<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Accounts:</h2> 
    <% for(let user of Object.values(data)) { %>
        <p>
            <a href="/insta/<%= user.username %>">
                <%= user.name %>
            </a>
        </p>     
    <% } %>
</body>
</html>