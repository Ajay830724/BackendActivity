<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        img{
            height:100px;
            width:100px;
        }
    </style>
</head>
<body>
    <h2>This page belongs to @<%= person.username %></h2>
    <button>Follow</button> <br><br>
    <p>Follower: <%= person.followers %> &nbsp; &nbsp; &nbsp; &nbsp;Follower: <%= person.following %></p>
    <hr>
    <h2>Posts</h2>
    <% for(let post of person.posts){ %>
        <div>
            <img src="<%= post.image %>" alt="loding..">
            <p>Likes: <%= post.likes %> &nbsp; &nbsp; &nbsp; &nbsp;Comments: <%= post.comments %></p>
        </div>
    <% } %>
</body>
</html>